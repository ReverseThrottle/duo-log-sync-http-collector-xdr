# ============================================================
# Cortex XDR HTTP Log Collector — required
# ============================================================

# Full HTTPS URL of the Cortex XDR HTTP Log Collector endpoint
# Example: https://api-<tenant>.xdr.us.paloaltonetworks.com/logs/v1/event
XDR_COLLECTOR_URL=https://api-<tenant>.xdr.us.paloaltonetworks.com/logs/v1/event

# API key value
XDR_API_KEY=your-api-key-value-here

# API key ID — only required for some XDR tenant configurations (omit if not needed)
# XDR_API_KEY_ID=

# ============================================================
# Duo Log Sync credentials — used by windows\setup.ps1 to write duo_log_sync\config.yml
#
# Fill these in before running setup.ps1 to avoid interactive prompts.
# You can also pass them directly as script parameters:
#   .\windows\setup.ps1 -DuoIkey "..." -DuoSkey "..." -DuoHostname "..."
#
# If DLS is already installed and configured on this host, leave these blank
# and pass -SkipDls to setup.ps1. The forwarder service does not use these
# values at runtime — they are only read during setup to generate config.yml.
# ============================================================

# Integration Key from your Duo Admin API application
# (Admin Panel -> Applications -> your Admin API app -> Integration Key)
DUO_IKEY=

# Secret Key — keep this safe, treat it like a password
DUO_SKEY=

# API hostname shown on the Duo Admin Panel application page
# Example: api-XXXXXXXX.duosecurity.com
DUO_HOSTNAME=

# ============================================================
# TCP listener — this is where Duo Log Sync sends its output
# ============================================================

# Address to bind the TCP listener on. Use 127.0.0.1 if DLS runs on the same host.
LISTEN_HOST=127.0.0.1

# Port to listen on. Must match the 'port' in DLS config.yml server block.
LISTEN_PORT=9999

# Maximum number of concurrent DLS TCP connections accepted.
# Connections beyond this limit are rejected immediately and logged as WARNING.
# Default: 10. In normal operation only one DLS instance connects at a time.
MAX_CONNECTIONS=10

# ============================================================
# Optional tuning
# ============================================================

# Dataset name for XDR routing (used in XQL queries)
XDR_DATASET=duo_logs

# Records per HTTP POST to XDR
BATCH_SIZE=100

# Seconds to wait before flushing a partial batch (when records trickle in slowly)
FLUSH_INTERVAL_SECONDS=5

# Logging verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Maximum retry attempts per batch before dropping and moving on
MAX_RETRIES=3

# Base backoff in seconds between retries (doubles each attempt)
RETRY_BACKOFF_SECONDS=5
